#Forward/nat requires net.ipv4.ip_forward=1
#*nat
#:PREROUTING ACCEPT
#:INPUT ACCEPT
#:POSTROUTING ACCEPT
#:OUTPUT ACCEPT
#COMMIT

*filter
:INPUT DROP
:FORWARD DROP
:OUTPUT ACCEPT
# Standard Rules
-A INPUT -p all -m state --state RELATED,ESTABLISHED -j ACCEPT
-A INPUT -p icmp -j ACCEPT
-A INPUT -p all -i lo -j ACCEPT
-A INPUT -m state --state NEW -p tcp --dport 22 -j ACCEPT
-A INPUT -p all -j REJECT --reject-with icmp-host-prohibited
-A FORWARD -p all -j REJECT --reject-with icmp-host-prohibited
COMMIT

#*mangle
#:PREROUTING ACCEPT
#:INPUT ACCEPT
#:FORWARD ACCEPT
#:OUTPUT ACCEPT
#:POSTROUTING ACCEPT
#COMMIT

#*raw
#:PREROUTING ACCEPT
#:OUTPUT ACCEPT
#COMMIT