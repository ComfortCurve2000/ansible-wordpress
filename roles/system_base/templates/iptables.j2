#Forward/nat requires net.ipv4.ip_forward=1
#*nat
#:PREROUTING ACCEPT
#:INPUT ACCEPT
#:POSTROUTING ACCEPT
#:OUTPUT ACCEPT
#COMMIT

*filter
:INPUT DROP
:FORWARD DROP
:OUTPUT ACCEPT
#INPUT
-A INPUT -p tcp -m state --state NEW -m tcp --dport 22 -j ACCEPT
-A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT
-A INPUT -p icmp -j ACCEPT
-A INPUT -i lo -j ACCEPT
-A INPUT -j DROP
#FORWARD
-A FORWARD -j REJECT --reject-with icmp-host-prohibited
COMMIT

#*mangle
#:PREROUTING ACCEPT
#:INPUT ACCEPT
#:FORWARD ACCEPT
#:OUTPUT ACCEPT
#:POSTROUTING ACCEPT
#COMMIT

#*raw
#:PREROUTING ACCEPT
#:OUTPUT ACCEPT
#COMMIT